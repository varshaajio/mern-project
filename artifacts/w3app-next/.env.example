# Copy this file to .env.local and fill in your values

# MongoDB Connection (Required)
# For local MongoDB: mongodb://localhost:27017/w3appdevelopers
# For MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/w3appdevelopers
MONGODB_URI=mongodb://localhost:27017/w3appdevelopers

# Next.js port (default: 3000)
PORT_NEXT=3000

# Express server port (default: 5000)
PORT_SERVER=5000

# Environment
NODE_ENV=development
