{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["es2017"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "dist/server",
    "rootDir": "src/server",
    "baseUrl": "."
  },
  "include": ["src/server/**/*"],
  "exclude": ["node_modules"]
}
